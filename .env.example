# ==================== DATABASE ====================
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Local: postgresql://postgres:postgres@localhost:5432/finance_db
# Render: postgresql://user@hostname/database (copy from Render dashboard)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_db"

# ==================== SERVER ====================
# Options: development, production, test
NODE_ENV=development
PORT=3000

# ==================== JWT AUTHENTICATION ====================
# Security: Generate with: openssl rand -base64 32
# Do NOT use the example value in production!
# Delete this line and add via GitHub Actions secrets or environment
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# ==================== RATE LIMITING ====================
# Window in milliseconds (900000 = 15 minutes)
# Max requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== API CONFIGURATION ====================
API_BASE_URL=http://localhost:3000
API_DOCS_ENABLED=true

# ==================== LOGGING ====================
# Options: error, warn, info, debug
LOG_LEVEL=debug

# ==================== DEPLOYMENT-SPECIFIC ====================
# Render: Enable for production deployments
# RENDER=true
# GCP/Cloud Run: Uncomment for serverless
# PORT=8080

# ==================== NOTES ====================
# 1. NEVER commit .env files to version control
# 2. Copy .env.example to .env and customize for your environment
# 3. Use GitHub Actions secrets for sensitive values in CI/CD
# 4. Update JWT_SECRET in production environments (see CI-CD-DEPLOYMENT.md)
